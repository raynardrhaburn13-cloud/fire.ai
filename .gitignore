"""
AI Chatbot using Hugging Face Inference API (Free Tier)
Supports both authenticated and unauthenticated requests.
"""

import os
import sys
import requests
from typing import Optional


def get_api_key() -> Optional[str]:
    """Get API key from environment or .env file."""
    try:
        from dotenv import load_dotenv
        load_dotenv()
    except ImportError:
        pass
    return os.getenv("HUGGINGFACE_API_KEY")


def chat_with_ai(user_message: str, api_key: Optional[str] = None) -> str:
    """
    Send a message to the AI and get a response.

    Uses Hugging Face's free Inference API with Zephyr 7B model.
    No API key required, but having one gives better rate limits.

    Args:
        user_message: The message to send to the AI
        api_key: Optional Hugging Face API key for better rate limits

    Returns:
        The AI's response text
    """
    API_URL = "https://api-inference.huggingface.co/models/HuggingFaceH4/zephyr-7b-beta"

    headers = {"Content-Type": "application/json"}
    if api_key:
        headers["Authorization"] = f"Bearer {api_key}"

    # Zephyr uses a specific chat format
    payload = {
        "inputs": f"<|system|>\nYou are a helpful, friendly AI assistant. Be concise but informative.\n<|user|>\n{user_message}\n<|assistant|>\n",
        "parameters": {
            "max_new_tokens": 512,
            "temperature": 0.7,
            "top_p": 0.9,
            "return_full_text": False
        }
    }

    try:
        response = requests.post(API_URL, headers=headers, json=payload, timeout=90)
        response.raise_for_status()
        result = response.json()

        if isinstance(result, list) and len(result) > 0:
            return result[0].get("generated_text", "No response received.").strip()
        return str(result)

    except requests.exceptions.Timeout:
        return "The model is loading. This is normal for the first request. Try again in 20-30 seconds."
    except requests.exceptions.HTTPError as e:
        if response.status_code == 429:
            return "Rate limit reached. Please wait a moment and try again, or add a free API key for higher limits."
        return f"HTTP Error: {e}"
    except Exception as e:
        return f"Error: {type(e).__name__}: {e}"


def print_banner():
    """Print the chatbot welcome banner."""
    print("=" * 50)
    print("       AI Chatbot - Zephyr 7B (Free)")
    print("=" * 50)
    print("Type your message and press Enter.")
    print("Commands: 'quit', 'exit', 'q' to stop")
    print("-" * 50)

    api_key = get_api_key()
    if api_key:
        print("API Key: Loaded (better rate limits)")
    else:
        print("API Key: Not set (free tier, may be slower)")
        print("Tip: Get a free key at huggingface.co/settings/tokens")
    print("-" * 50 + "\n")


def main():
    """Main chat loop."""
    print_banner()

    api_key = get_api_key()

    while True:
        try:
            user_input = input("You: ").strip()
        except (KeyboardInterrupt, EOFError):
            print("\nGoodbye!")
            break

        if user_input.lower() in ("quit", "exit", "q"):
            print("Goodbye!")
            break
        if not user_input:
            continue

        print("AI is thinking...")
        reply = chat_with_ai(user_input, api_key)
        print(f"AI: {reply}\n")


if __name__ == "__main__":
    main()
